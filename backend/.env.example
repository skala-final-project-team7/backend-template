# =============================================================================
# LINA Backend — 로컬 실행용 환경변수 템플릿
# =============================================================================
# 사용법:
#   1) 이 파일을 복사한다:        cp backend/.env.example backend/.env
#   2) 아래 빈 값(특히 키)을 채운다 (생성 명령은 각 항목 주석 참고)
#   3) 서버 실행 전에 환경변수로 로드한다:
#         set -a; source backend/.env; set +a
#         (cd backend && ./gradlew :auth-server:bootRun)   # 포트 8081
#         (cd backend && ./gradlew :bff-server:bootRun)    # 포트 8080
#
# ⚠️ 이 프로젝트는 .env 를 자동으로 읽지 않는다(dotenv 로더 없음).
#    Spring 은 OS 환경변수에서 ${VAR} 를 해석하므로 반드시 위처럼 source 후 실행한다.
# ⚠️ backend/.env 는 .gitignore 로 무시된다. 실제 secret 을 커밋하지 말 것.
# 기본 active profile = local (application-local.yml). 미지정 시 local 로 동작.
# =============================================================================


# ======================= auth-server (포트 8081) =============================

# --- MySQL (Flyway 마이그레이션 + JPA validate 가 부팅 시 실행됨) ---
# 로컬에 lina_auth 스키마가 있어야 한다:  CREATE DATABASE lina_auth;
MYSQL_URL=jdbc:mysql://localhost:3306/lina_auth
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# --- JWT 서명 키 (RS256) — 비어 있으면 auth-server 부팅 실패(fail-fast) ---
# RSA 키쌍 생성 (PEM 한 줄로 환경변수에 넣기):
#   openssl genrsa -out jwt-private.pem 2048
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
# PEM 전체(개행 포함)를 그대로 따옴표로 감싸 넣으면 된다. 예:
#   LINA_JWT_PRIVATE_KEY="$(cat jwt-private.pem)"
LINA_JWT_PRIVATE_KEY=
LINA_JWT_PUBLIC_KEY=
LINA_JWT_ISSUER=lina-auth-server
LINA_JWT_ACCESS_TTL=3600
LINA_JWT_REFRESH_TTL=1209600

# --- 토큰 컬럼 AES-GCM 암호화 키 — 비어 있으면 부팅 실패(fail-fast) ---
# Base64 인코딩된 AES 키. 32바이트(AES-256) 생성:
#   openssl rand -base64 32
LINA_TOKEN_ENCRYPTION_KEY=

# --- 내부 API 공유 키 (/internal/** 호출자 인증) — 미설정 시 내부 API 전부 거부 ---
#   openssl rand -hex 32
INTERNAL_API_KEY=

# --- Confluence OAuth (실제 로그인 플로우를 돌릴 때만 필요) ---
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=
CONFLUENCE_AUTHORIZATION_URI=
CONFLUENCE_TOKEN_URI=
CONFLUENCE_USER_INFO_URI=
CONFLUENCE_REDIRECT_URI=
# 미리보기(§4-3)는 Confluence v2 API 를 쓰므로 granular scope 필요(read:page:confluence/read:space:confluence).
# Atlassian 앱에 해당 scope 활성 + 값 변경 후 재로그인해야 토큰에 반영됨(refresh 로는 scope 안 늘어남).
CONFLUENCE_SCOPES=read:me read:confluence-content.all read:confluence-user read:confluence-groups read:confluence-space.summary read:page:confluence read:space:confluence offline_access
CONFLUENCE_API_BASE_URI=https://api.atlassian.com
CONFLUENCE_SITE_URL=
OAUTH_STATE_TTL_SECONDS=600

# --- Atlassian Admin Key 지속시간(분, 최대 60) ---
ADMIN_KEY_DURATION_MINUTES=60

# --- 최초 admin seed (전부 채워야 seed 실행, 하나라도 비면 건너뜀 — 선택) ---
LINA_ADMIN_ACCOUNT_ID=
LINA_ADMIN_EMAIL=
LINA_ADMIN_NAME=
LINA_ADMIN_SITE_URL=
LINA_ADMIN_API_TOKEN=


# ========================= bff-server (포트 8080) ============================

# --- MongoDB (local 프로필 기본값으로도 동작) ---
BFF_MONGODB_URI=mongodb://localhost:27017
BFF_MONGODB_DATABASE=lina_local

# --- RAG / Data Ingestion / auth-server 연동 (local 기본값 존재) ---
ML_PIPELINE_BASE_URL=http://localhost:8000
DATA_INGESTION_BASE_URL=http://localhost:8000
AUTH_SERVER_BASE_URL=http://localhost:8081

# --- RabbitMQ (admin ingest 메시징) — 명시 설정이 없으면 Spring 기본값 사용 ---
# 로컬 RabbitMQ 기본: localhost:5672, guest/guest. 필요 시 아래 주석 해제.
# SPRING_RABBITMQ_HOST=localhost
# SPRING_RABBITMQ_PORT=5672
# SPRING_RABBITMQ_USERNAME=guest
# SPRING_RABBITMQ_PASSWORD=guest

# --- BFF 는 JWT 공개키만 보유(검증 전용). auth-server 와 동일 값 사용 ---
LINA_JWT_PUBLIC_KEY=

# --- Admin 대시보드 MySQL 직접 조회 (선택, 기본 비활성) ---
ADMIN_DASHBOARD_MYSQL_ENABLED=false
# ADMIN_DASHBOARD_MYSQL_JDBC_URL=jdbc:mysql://localhost:3306/lina_auth
# ADMIN_DASHBOARD_MYSQL_USERNAME=root
# ADMIN_DASHBOARD_MYSQL_PASSWORD=
